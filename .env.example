# Vision tagging provider — ONE of: openai, claude, gemini
# If the selected provider's key is missing, auto-falls back to whichever key is present.
AUTO_TAG_PROVIDER=openai

# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_AUTO_TAG_MODEL=gpt-5.4-nano

# Anthropic Claude (alternative provider)
ANTHROPIC_API_KEY=
CLAUDE_AUTO_TAG_MODEL=claude-haiku-4-5

# Google Gemini (alternative provider)
GEMINI_API_KEY=
GEMINI_AUTO_TAG_MODEL=gemini-2.5-flash

# Semantic search (optional — falls back to keyword search without it)
VOYAGE_API_KEY=
CLEAN_UI_PORT=3131
