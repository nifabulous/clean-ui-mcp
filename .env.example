# Vision tagging provider — ONE of: openai, claude, gemini
# If the selected provider's key is missing, auto-falls back to whichever key is present.
AUTO_TAG_PROVIDER=openai

# Optional: use different providers for each pass of the two-pass tagger.
# Extraction (Pass 1) needs vision + speed; critique (Pass 2) needs reasoning + writing.
# Recommended: Gemini Flash for extraction, Claude Sonnet for critique.
# If unset, both fall back to AUTO_TAG_PROVIDER above.
#AUTO_TAG_PROVIDER_EXTRACTION=gemini
#AUTO_TAG_PROVIDER_CRITIQUE=claude

# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_AUTO_TAG_MODEL=gpt-5.4-nano

# Anthropic Claude (alternative provider)
ANTHROPIC_API_KEY=
CLAUDE_AUTO_TAG_MODEL=claude-sonnet-4-5

# Google Gemini (alternative provider)
GEMINI_API_KEY=
GEMINI_AUTO_TAG_MODEL=gemini-3.5-flash

# OpenAI-compatible endpoints (NIM, OpenRouter, Together, Groq, vLLM).
# Setting OPENAI_BASE_URL routes OpenAI calls to /v1/chat/completions instead
# of OpenAI's native /v1/responses. Per-pass overrides (_EXTRACTION / _CRITIQUE)
# let extraction and critique hit different OpenAI-compatible endpoints — e.g.
# real OpenAI for extraction (vision), NIM DeepSeek V4 for critique (writing).
# See README "Multi-provider support" for a full DeepSeek-on-NIM example.
#OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#OPENAI_BASE_URL_CRITIQUE=https://integrate.api.nvidia.com/v1
#OPENAI_API_KEY_CRITIQUE=nvapi-...
#OPENAI_AUTO_TAG_MODEL_CRITIQUE=deepseek-ai/deepseek-v4-pro

# Optional tuning
# Set to 1 to print per-call provider config + token usage to stderr.
#DEBUG_TAGGER=1
# Forces thinking OFF for both passes on OpenAI-compatible providers (NIM etc).
#OPENAI_THINKING_DISABLED=1

# Semantic search (optional — falls back to keyword search without it)
VOYAGE_API_KEY=
CLEAN_UI_PORT=3131
