node_modules/
dist/
.worktrees/
*.log
.env
.env.local

# macOS Finder metadata — never useful, shows up in git status constantly
.DS_Store

# Test artifacts (Playwright screenshots, smoke output)
output/

# Never publish privately-sourced raster images
corpus/images-private/*
!corpus/images-private/.gitkeep

# Public-corpus images — currently uncleared (placeholder rights only).
# Gitignored so they're never accidentally committed/published. Before Gate 2
# (npm publish) or Gate 3 (hosted), one of two things must happen:
#   (a) A reviewed, rights-cleared subset is explicitly tracked in git so a
#       CI/GitHub Actions OIDC release can reproduce the npm artifact. Use
#       `git add -f corpus/images-public/<cleared-file>` per reviewed asset.
#   (b) An authenticated, integrity-checked asset-fetch step downloads
#       reviewed assets at build time from a secured source.
# Either way, blanket-ignoring is correct NOW (the content is uncleared) but
# must be resolved before real distribution — not deferred indefinitely.
corpus/images-public/*
!corpus/images-public/.gitkeep

# Local working corpus — your private curation (references gitignored images,
# product names, critique text). NOT publishable. The repo ships corpus/seed.json
# as a minimal schema example; entries.json is created locally via the UI/CLI.
# Snapshots + restore-corpus protect against loss.
corpus/entries.json

# Local working decisions (Decision Lab) — the user's own comparison briefs,
# created via the UI/CLI. Like entries.json, this is a private working file, not
# part of the publishable corpus. Rolling snapshots protect against loss.
corpus/decisions.json

# Derived — regenerate with `npm run build-index`
corpus/embeddings.json
# Derived — image embeddings, regenerate with `npm run build-image-index`
corpus/image-embeddings.json
# Derived — dHash fingerprint cache, rebuilt by the curator UI at runtime
corpus/.dhash-cache.json
# Derived — MCP query log (retrieval analytics), populated at runtime by the server
corpus/query-log.jsonl

# Eval baselines — machine/provider-specific (latency, model, private images).
# Regenerate with `npm run eval-baseline`. Not portable across machines.
# Tracked C2 design-handoff gold contracts are an exception: synthetic, portable
# (no provider data), and required deliverables of the grounded-design pre-C2
# plan. Un-ignore the directory so git descends into it, re-ignore everything,
# then carve the two tracked files back out.
eval/*
!eval/design-handoff-labels.json
# C2 Pass 2 v1 regression matrix (Task 2): synthetic, portable v1 candidates
# and their committed score baseline. Same rationale as the labels file —
# required deliverables of the v1 scorer regression gate, no provider data.
!eval/design-handoff-v1-candidates.json
!eval/design-handoff-v1-score-baseline.json
!eval/design-handoff-fixtures/
eval/design-handoff-fixtures/*
!eval/design-handoff-fixtures/briefs.json
!eval/design-handoff-fixtures.test.mjs
# C2 separated pilot packages (Task 4): synthetic, portable gold contracts for
# the product/migration/safety pilot cases. Same rationale as the design-handoff
# carve-out above — required deliverables, no provider data, no private corpus.
# Un-ignore each directory level so git descends into them, then carve the
# tracked JSON back out at the leaves.
!eval/c2/
eval/c2/*
!eval/c2/pilot/
eval/c2/pilot/*
!eval/c2/pilot/briefs/
!eval/c2/pilot/labels/
!eval/c2/pilot/source-snapshots/
!eval/c2/pilot/evidence/
# C2 Pass 3 stablecoin product case packages: synthetic, portable gold contracts
# (briefs + decision labels + gold-evidence descriptors) for the four new
# product-family baseline cases. Same rationale as the pilot carve-out above —
# required deliverables, no provider data, no private corpus, no source
# snapshots (product family binds sourceSnapshotRef: null).
!eval/c2/baseline/
eval/c2/baseline/*
!eval/c2/baseline/briefs/
!eval/c2/baseline/labels/
!eval/c2/baseline/evidence/
!eval/c2/baseline/source-snapshots/
# C2 Pass 3 baseline manifest (Task B5): the canonical content-addressed binding
# of the 25 frozen baseline cases (3 pilot + 22 new). Tracked because downstream
# gates validate against it via `npm run validate:c2-baseline`. Carries only
# hashes + refs (no prompt/evidence/raw content, no secrets, no private paths) —
# verified to pass scanDurableArtifact on every build + check.
!eval/c2/baseline/manifest.json
# C2 reviewed campaign + pricing config (Task 5): non-secret provider/model
# pins, sampling parameters, output-token ceilings, fixed $0.50/$5 budgets,
# and a versioned pricing table with provenance URLs + verification dates.
# Stores apiKeyEnv NAMES only (OPENAI_API_KEY / ANTHROPIC_API_KEY), never key
# values. Pricing values are placeholders that must be re-verified from
# official provider sources immediately before the paid campaign. Tracked
# because the paid-call harness and calibration reducer bind these hashes.
!eval/c2/config/
# C2 Pass 2 frozen calibration (Task 10): the byte-identical-deterministic
# frozen artifact bound to the human-authorized compatibility evaluation. Both
# frozen.json (the reproducible calibration deliverable) and proposal.json (the
# reduced measurements the freeze binds via proposalRef) are tracked. Tracking
# proposal.json makes the frozen calibration fully auditable: proposal.json
# (the reduced measurements) + the run/scorecard refs (the raw evidence
# bindings) are all traceable. Both pass the boundary scanner (hashes +
# metadata only, no prompt/evidence/raw content).
!eval/c2/calibration/
eval/c2/calibration/*
!eval/c2/calibration/frozen.json
!eval/c2/calibration/proposal.json
# C2 Pass 3 frozen label-integrity selection (Task A2): the deterministic
# 35-reproducible + 5-challenge selection bound to the corpus + commit SHAs.
# Tracked because downstream label submissions + agreement reports bind its
# artifactId + content hash. Carries only entry IDs + image SHA-256 + rationales
# + corpus/git hashes — verified to pass scanDurableArtifact (no prompt/evidence/
# raw content, no secrets, no private paths).
!eval/c2/label-integrity/
eval/c2/label-integrity/*
!eval/c2/label-integrity/selection.json
# C2 Pass 2 frozen-calibration evidence bundle: the run manifests + human
# scorecards the frozen calibration binds by hash. These are hash-only
# metadata (no prompt/evidence/raw content, no secrets) — verified to pass
# scanDurableArtifact. Tracked so a fresh clone can independently audit every
# hash binding in frozen.json. Raw responses, blinded reviewer packets, and
# the failed runs without score.json all stay gitignored under their own
# rules; only the 11 succeeded run manifests + their score.json + the 11
# canonical scorecards are git-added with -f below.
!eval/c2/runs/
eval/c2/runs/*
!eval/c2/scorecards/
eval/c2/scorecards/*
# C2 gold-evidence descriptors (Task 3): each descriptor maps every label
# goldEvidenceId to exact source JSON pointers (brief fields or migration
# snapshot fields). Tracked because the pilot manifest binds their resolved
# hashes, and downstream gates validate the binding via
# `npm run validate:c2-pilot`. No prose duplication, no reviewer fields.
# C2 pilot manifest (Task 5): the canonical content-addressed binding of the
# three pilot packages. Tracked because downstream gates validate against it
# via `npm run validate:c2-pilot`.
!eval/c2/pilot/manifest.json
# Durability — rolling snapshots of entries.json, written on every UI save.
# Gitignored because they're large, derivable, and purely a local safety net.
corpus/.snapshots/

# C2 Pass 2 private run directory (Task 6). Raw responses, parsed candidates,
# detailed evidence payloads, full condition inputs, and corpus snapshots live
# here. These are NEVER committable — only their hashes + metadata may reach a
# durable artifact, and a boundary scanner enforces that before any write.
# Tracked durable artifacts (deterministic scores, calibration proposals,
# frozen calibration) live elsewhere and pass the scan.
.c2-private/

# Bulk-import working state. Draft files are the staged-but-uncommitted output
# of `npm run bulk-import`; their .bak siblings come from the strip-and-approve
# helper. Per-batch manifests (bulk-*-manifest.json) ARE kept — they record
# exactly which images were in each batch. Staging folders hold extracted zips
# mid-import. All transient, all local.
corpus/*-draft.json
corpus/*-draft.json.bak
corpus/staging-*/
corpus/bulk-test-*

# Local corpus config — per-curator floor for the entry-count drift check.
# Copy .corpus-config.example.json to .corpus-config.json and set your floor.
corpus/.corpus-config.json

# Public snapshots — generated by the publication exporter. Contains the
# (potentially uncleared) image bytes eligible for distribution. Never commit;
# these are local-only until an explicit Gate 2 npm-publish or Gate 3 host step
# deliberately ships them. See docs/superpowers/specs/*-gate-1a-design.md.
corpus/public-snapshots/

# ZCode per-machine/session state — allowlist only the deliberately-shared paths.
# Everything else under .zcode/ is local (reviews, tmp, plans, debug markers).
.zcode/*
!.zcode/config.json
!.zcode/git-hooks/
!.zcode/hooks/
!.zcode/scripts/
!.zcode/code-reviewer.md

# Superpowers session state
.superpowers/

# Worktrees (stale checkouts cause test double-counting)
.worktrees/
