{
  "hooks": {
    "enabled": true,
    "events": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "${ZCODE_PROJECT_DIR}/.zcode/hooks/probe-hook",
              "timeout": 5
            }
          ]
        }
      ]
    }
  }
}
