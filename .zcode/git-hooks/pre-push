#!/usr/bin/env bash
# pre-push — git native pre-push hook.
# Blocks pushes unless each pushed branch's local SHA has an approved
# branch-review artifact at .zcode/reviews/branches/<branch>.json with a
# matching headSha.
#
# Bypass: ZCODE_BYPASS_REVIEW=1 git push (logged + visible warning)
# Main/master branches are exempt (trunk pushes aren't feature work).
#
# Install: .zcode/scripts/install-git-hooks
set -euo pipefail

# Resolve ROOT with symlink safety (C4 fix).
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "${ZCODE_PROJECT_DIR:-$(pwd)}")"
ZCODE_DIR="$ROOT/.zcode"
if [ -L "$ZCODE_DIR" ]; then
  echo "  ⚠  .zcode is a symlink — refusing to operate (security). Remove the symlink." >&2
  exit 1
fi

# Read stdin and parse per-ref data. Git pre-push stdin format is:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# per line, one line per ref being pushed. We collect the remote branch name
# AND its local SHA so we validate against the actual ref being pushed, not
# against the checked-out branch's HEAD.
STDIN_LINES="$(cat || true)"

# Build a list of "branch:localsha" entries for refs/heads/* pushes.
PUSH_ENTRIES=""
while IFS= read -r LINE 2>/dev/null; do
  [ -z "$LINE" ] && continue
  LOCAL_REF="$(echo "$LINE" | awk '{print $1}')"
  LOCAL_SHA="$(echo "$LINE" | awk '{print $2}')"
  REMOTE_REF="$(echo "$LINE" | awk '{print $3}')"
  case "$REMOTE_REF" in
    refs/heads/*)
      B="$(echo "$REMOTE_REF" | sed 's|^refs/heads/||')"
      PUSH_ENTRIES="$PUSH_ENTRIES $B:$LOCAL_SHA"
      ;;
  esac
done <<< "$STDIN_LINES"

# If no branch refs pushed (e.g. tags only), allow.
if [ -z "$PUSH_ENTRIES" ]; then
  exit 0
fi

# Emergency bypass with audit log.
CHECKED_BRANCH="$(git branch --show-current 2>/dev/null || echo '')"
if [ -z "$CHECKED_BRANCH" ]; then
  CHECKED_BRANCH="detached-$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
fi
CHECKED_SHA="$(git rev-parse HEAD 2>/dev/null || echo '')"

if [ "${ZCODE_BYPASS_REVIEW:-}" = "1" ]; then
  mkdir -p "$ZCODE_DIR/reviews"
  PUSHED_NAMES="$(echo "$PUSH_ENTRIES" | tr ' ' '\n' | cut -d: -f1 | xargs)"
  python3 -c '
import json, sys
entry = {"ts": sys.argv[1], "checkedBranch": sys.argv[2], "checkedSha": sys.argv[3], "hook": "pre-push", "bypass": True, "pushedBranches": sys.argv[4]}
print(json.dumps(entry))
' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$CHECKED_BRANCH" "$CHECKED_SHA" "$PUSHED_NAMES" \
    >> "$ZCODE_DIR/reviews/bypass-log.jsonl"
  echo "  ⚠  ⚠  ⚠  REVIEW BYPASS (pre-push) — push will be unreviewed. Logged." >&2
  exit 0
fi

# Check each pushed branch against its own local SHA (P1 fix: was using a single
# HEAD_SHA for all branches, which is wrong for multi-ref pushes or pushes of
# branches other than the checked-out one).
BLOCKED=0
for ENTRY in $PUSH_ENTRIES; do
  PUSH_BRANCH="${ENTRY%%:*}"
  LOCAL_SHA="${ENTRY#*:}"

  # Exempt trunk branches.
  case "$PUSH_BRANCH" in
    main|master) continue ;;
  esac

  # Skip zero SHA (branch deletion) — no review needed for deleting a remote ref.
  case "$LOCAL_SHA" in
    0000000000000000000000000000000000000000) continue ;;
  esac

  # URL-safe encoding for the artifact filename (I1 fix).
  BRANCH_SAFE="$(python3 -c "
import urllib.parse, sys
print(urllib.parse.quote(sys.argv[1], safe=''))
" "$PUSH_BRANCH" 2>/dev/null || echo "$PUSH_BRANCH" | tr '/' '-')"

  ARTIFACT="$ZCODE_DIR/reviews/branches/$BRANCH_SAFE.json"

  if [ ! -f "$ARTIFACT" ]; then
    echo "" >&2
    echo "  ⛔ PUSH BLOCKED: no branch review for $PUSH_BRANCH" >&2
    echo "" >&2
    echo "  Branch $PUSH_BRANCH (local SHA $LOCAL_SHA) has no holistic review artifact." >&2
    echo "  Run the branch review, then write the artifact:" >&2
    echo "" >&2
    echo "    .zcode/scripts/write-review-artifact \\" >&2
    echo "      --type branch --result approved --reviewer agent \\" >&2
    echo "      --base-sha <base> --head-sha $LOCAL_SHA \\" >&2
    echo "      --branch $PUSH_BRANCH" >&2
    echo "" >&2
    echo "  Emergency bypass: ZCODE_BYPASS_REVIEW=1 git push" >&2
    echo "" >&2
    BLOCKED=1
    continue
  fi

  # Validate artifact: result must be approved, headSha must match the ref's
  # local SHA (NOT the checked-out HEAD — P1 fix).
  RESULT="$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("result",""))' "$ARTIFACT" 2>/dev/null || echo "")"
  REVIEWED_SHA="$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("headSha",""))' "$ARTIFACT" 2>/dev/null || echo "")"

  if [ "$RESULT" != "approved" ]; then
    echo "" >&2
    echo "  ⛔ PUSH BLOCKED: branch review not approved for $PUSH_BRANCH" >&2
    echo "" >&2
    echo "  Branch $PUSH_BRANCH review exists but result is '$RESULT', not 'approved'." >&2
    echo "  Address the review findings, then re-approve." >&2
    echo "" >&2
    BLOCKED=1
    continue
  fi

  if [ "$REVIEWED_SHA" != "$LOCAL_SHA" ]; then
    echo "" >&2
    echo "  ⛔ PUSH BLOCKED: branch review is stale for $PUSH_BRANCH" >&2
    echo "" >&2
    echo "  Branch $PUSH_BRANCH was reviewed at $REVIEWED_SHA but local SHA is $LOCAL_SHA." >&2
    echo "  New commits since the review need re-review before pushing." >&2
    echo "" >&2
    echo "  Re-run the branch review, then:" >&2
    echo "" >&2
    echo "    .zcode/scripts/write-review-artifact \\" >&2
    echo "      --type branch --result approved --reviewer agent \\" >&2
    echo "      --base-sha $REVIEWED_SHA --head-sha $LOCAL_SHA \\" >&2
    echo "      --branch $PUSH_BRANCH" >&2
    echo "" >&2
    echo "  Emergency bypass: ZCODE_BYPASS_REVIEW=1 git push" >&2
    echo "" >&2
    BLOCKED=1
    continue
  fi

  echo "  ✓ Branch review verified for $PUSH_BRANCH ($LOCAL_SHA)" >&2
done

if [ "$BLOCKED" = "1" ]; then
  exit 1
fi
exit 0
