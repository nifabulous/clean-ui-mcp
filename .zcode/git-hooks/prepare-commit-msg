#!/usr/bin/env bash
# prepare-commit-msg — git native prepare-commit-msg hook.
# Blocks new commits when the previous task commit (current HEAD) lacks an
# approved task-review artifact at .zcode/reviews/tasks/<headSha>.json.
#
# This enforces the "review after each task" rule: after committing task N,
# you must review it before committing task N+1.
#
# Bypass: ZCODE_BYPASS_REVIEW=1 git commit ... (logged + visible warning)
# Merge commits are exempt. Initial commits are exempt.
#
# Install: .zcode/scripts/install-git-hooks
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Resolve ROOT with symlink safety (C4 fix). Refuse if .zcode is a symlink.
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "${ZCODE_PROJECT_DIR:-$(pwd)}")"
ZCODE_DIR="$ROOT/.zcode"
if [ -L "$ZCODE_DIR" ]; then
  echo "  ⚠  .zcode is a symlink — refusing to operate (security). Remove the symlink." >&2
  exit 1
fi

BRANCH="$(git branch --show-current 2>/dev/null || echo '')"
# Fix I4: detached HEAD yields empty string, not "unknown".
if [ -z "$BRANCH" ]; then
  BRANCH="detached-$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
fi
HEAD_SHA="$(git rev-parse HEAD 2>/dev/null || echo '')"

# Exempt: merge commits only (C2 fix — removed 'commit' and 'squash' sources
# which covered -C/-c/--amend). Merge commits are safe to exempt because they
# don't represent new task work.
case "$COMMIT_SOURCE" in
  merge) exit 0 ;;
esac

# If HEAD has no parent (initial commit), nothing to review.
if ! git rev-parse HEAD^ >/dev/null 2>&1; then
  exit 0
fi

# Exempt trunk branches.
case "$BRANCH" in
  main|master) exit 0 ;;
esac

# C1 fix (bootstrap): if HEAD is reachable from main or master, it's a trunk
# commit that predates the hooks — no task review exists or should exist.
# Without this, the first feature commit after branching is permanently blocked.
for trunk in main master; do
  if git merge-base --is-ancestor "$HEAD_SHA" "$trunk" 2>/dev/null; then
    exit 0
  fi
done

# Emergency bypass with audit log (I2 fix: visible warning + logged).
if [ "${ZCODE_BYPASS_REVIEW:-}" = "1" ]; then
  mkdir -p "$ZCODE_DIR/reviews"
  python3 -c '
import json, sys
entry = {"ts": sys.argv[1], "branch": sys.argv[2], "headSha": sys.argv[3], "hook": "prepare-commit-msg", "bypass": True}
print(json.dumps(entry))
' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$BRANCH" "$HEAD_SHA" \
    >> "$ZCODE_DIR/reviews/bypass-log.jsonl"
  echo "  ⚠  ⚠  ⚠  REVIEW BYPASS (prepare-commit-msg) — commit will be unreviewed. Logged." >&2
  exit 0
fi

# C3 fix: scope chore(hooks):/chore(review): exemption to commits that touch
# ONLY .zcode/ files. Previously any commit message with these prefixes bypassed
# the gate regardless of what was staged.
if [ -f "$COMMIT_MSG_FILE" ]; then
  FIRST_LINE="$(head -1 "$COMMIT_MSG_FILE" 2>/dev/null || echo '')"
  case "$FIRST_LINE" in
    chore\(review\):*|chore\(hooks\):*)
      # Only exempt if ALL staged files are under .zcode/
      STAGED_NON_ZCODE="$(git diff --cached --name-only 2>/dev/null | grep -v '^\.zcode/' || true)"
      if [ -z "$STAGED_NON_ZCODE" ]; then
        exit 0
      fi
      ;;
  esac
fi

# Check for task-review artifact at current HEAD.
[ -n "$HEAD_SHA" ] || exit 0
TASK_ARTIFACT="$ZCODE_DIR/reviews/tasks/$HEAD_SHA.json"
if [ ! -f "$TASK_ARTIFACT" ]; then
  echo "" >&2
  echo "  ⛔ COMMIT BLOCKED: previous task not reviewed" >&2
  echo "" >&2
  echo "  HEAD $HEAD_SHA (branch $BRANCH) has no approved task-review artifact." >&2
  echo "  Review the work at this commit, then write the artifact:" >&2
  echo "" >&2
  echo "    .zcode/scripts/write-review-artifact \\" >&2
  echo "      --type task --result approved --reviewer agent \\" >&2
  echo "      --base-sha <parent> --head-sha $HEAD_SHA \\" >&2
  echo "      --branch $BRANCH" >&2
  echo "" >&2
  echo "  Then retry the commit. Emergency bypass: ZCODE_BYPASS_REVIEW=1 git commit ..." >&2
  echo "" >&2
  exit 1
fi

# Validate: result must be approved.
# Pass path via sys.argv (M7 from review).
RESULT="$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("result",""))' "$TASK_ARTIFACT" 2>/dev/null || echo "")"
if [ "$RESULT" != "approved" ]; then
  echo "" >&2
  echo "  ⛔ COMMIT BLOCKED: task review not approved" >&2
  echo "" >&2
  echo "  Task review for $HEAD_SHA exists but result is '$RESULT'." >&2
  echo "  Address the review findings, then re-approve." >&2
  echo "" >&2
  exit 1
fi

exit 0
