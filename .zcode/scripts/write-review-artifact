#!/usr/bin/env bash
# write-review-artifact — write a task or branch review artifact as JSON.
#
# Usage:
#   write-review-artifact --type task|branch \
#     --result approved|changes-requested \
#     --reviewer human|agent \
#     --base-sha <sha> --head-sha <sha> \
#     --branch <branch> \
#     [--issues '{"critical":0,"important":1,"minor":2}']
#
# Task artifacts:   .zcode/reviews/tasks/<headSha>.json
# Branch artifacts: .zcode/reviews/branches/<url-encoded-branch>.json
# (the writer URL-encodes branch names so names such as feat/ui are injective.)
set -euo pipefail

TYPE=""
RESULT=""
REVIEWER=""
BASE_SHA=""
HEAD_SHA=""
BRANCH=""
ISSUES=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --type) TYPE="$2"; shift 2 ;;
    --result) RESULT="$2"; shift 2 ;;
    --reviewer) REVIEWER="$2"; shift 2 ;;
    --base-sha) BASE_SHA="$2"; shift 2 ;;
    --head-sha) HEAD_SHA="$2"; shift 2 ;;
    --branch) BRANCH="$2"; shift 2 ;;
    --issues) ISSUES="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

[ -n "$TYPE" ] && [ -n "$RESULT" ] && [ -n "$REVIEWER" ] && [ -n "$BASE_SHA" ] && [ -n "$HEAD_SHA" ] && [ -n "$BRANCH" ] || {
  echo "missing required args. Need: --type --result --reviewer --base-sha --head-sha --branch" >&2
  exit 1
}

# Validate enum values (M4 from review).
case "$TYPE" in task|branch) ;; *) echo "invalid --type: $TYPE (expected task|branch)" >&2; exit 1 ;; esac
case "$RESULT" in approved|changes-requested) ;; *) echo "invalid --result: $RESULT (expected approved|changes-requested)" >&2; exit 1 ;; esac
case "$REVIEWER" in human|agent) ;; *) echo "invalid --reviewer: $REVIEWER (expected human|agent)" >&2; exit 1 ;; esac

# I2 fix: validate SHA format to prevent path traversal (e.g. --head-sha "../../pwned").
# Git SHAs are 40 hex chars (SHA-1) or 64 hex chars (SHA-256). Zero-SHA is also valid.
case "$HEAD_SHA" in
  *[!0-9a-f]*)
    echo "invalid --head-sha: must be hex characters only (got: $HEAD_SHA)" >&2
    exit 1
    ;;
esac
case ${#HEAD_SHA} in
  40|64) ;;
  *) echo "invalid --head-sha: must be 40 or 64 hex chars (got ${#HEAD_SHA}: $HEAD_SHA)" >&2; exit 1 ;;
esac
case "$BASE_SHA" in
  *[!0-9a-f]*)
    echo "invalid --base-sha: must be hex characters only (got: $BASE_SHA)" >&2
    exit 1
    ;;
esac

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "${ZCODE_PROJECT_DIR:-$(pwd)}")"
ZCODE_DIR="$ROOT/.zcode"
# C4 fix: refuse if .zcode is a symlink (security).
if [ -L "$ZCODE_DIR" ]; then
  echo "  ⚠  .zcode is a symlink — refusing to operate (security). Remove the symlink." >&2
  exit 1
fi
mkdir -p "$ZCODE_DIR/reviews/tasks" "$ZCODE_DIR/reviews/branches"
NOW="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

# I1 fix: URL-encode the branch name for the filename so the mapping is
# injective (feat/ab and feat-ab produce different files). The full branch
# name is preserved in the JSON "branch" field.
BRANCH_SAFE="$(python3 -c "
import urllib.parse, sys
print(urllib.parse.quote(sys.argv[1], safe=''))
" "$BRANCH" 2>/dev/null || echo "$BRANCH" | tr '/' '-')"

if [ "$TYPE" = "task" ]; then
  TARGET="$ZCODE_DIR/reviews/tasks/$HEAD_SHA.json"
else
  TARGET="$ZCODE_DIR/reviews/branches/$BRANCH_SAFE.json"
fi

# Build the artifact JSON using python3's json.dumps so branch names, SHAs,
# and other values containing quotes/backticks/$() can't break out of the JSON
# or execute as shell (C1/I1 from review). The values are passed via sys.argv,
# never interpolated into the Python source string.
python3 - "$TARGET" "$TYPE" "$BRANCH" "$BASE_SHA" "$HEAD_SHA" "$NOW" "$REVIEWER" "$RESULT" "$ISSUES" <<'PY'
import json, sys, os

target, rtype, branch, base_sha, head_sha, now, reviewer, result, issues_raw = sys.argv[1:10]

# Parse issues if provided, default to empty object.
try:
    issues = json.loads(issues_raw) if issues_raw else {}
except (json.JSONDecodeError, TypeError):
    print(f"warning: --issues is not valid JSON, using empty object: {issues_raw}", file=sys.stderr)
    issues = {}

doc = {
    "type": f"{rtype}-review",
    "branch": branch,
    "baseSha": base_sha,
    "headSha": head_sha,
    "reviewedAt": now,
    "reviewer": reviewer,
    "result": result,
    "issues": issues,
}

with open(target, "w") as f:
    json.dump(doc, f, indent=2)
    f.write("\n")
PY

echo "wrote $TARGET"
