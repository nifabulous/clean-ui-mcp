{
  "name": "clean-ui-mcp",
  "version": "0.2.0",
  "description": "MCP server exposing a curated corpus of exceptional UI examples for AI-assisted design.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "clean-ui-mcp": "dist/server.js"
  },
  "scripts": {
    "generate-references": "node scripts/generate-reference-artifacts.mjs",
    "validate-references": "node scripts/generate-reference-artifacts.mjs --check && tsc && node dist/references/loader.js",
    "check-public-site-boundary": "node scripts/check-public-site-boundary.mjs",
    "build": "npm run check-public-site-boundary && npm run validate:c2-pilot && npm run validate:c2-label-selection:schema && npm run validate:c2-baseline && npm run generate-references && tsc",
    "start": "node dist/server.js",
    "dev": "tsc && node dist/server.js",
    "ui": "tsc && node dist/scripts/ui-server.js",
    "validate-corpus": "tsc && node dist/scripts/validate-corpus.js",
    "tag-image": "tsc && node dist/scripts/tag-image.js",
    "add-entry": "tsc && node dist/scripts/add-entry.js",
    "capture": "tsc && node dist/scripts/capture.js",
    "capture-batch": "tsc && node dist/scripts/capture.js",
    "test": "vitest run",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts",
    "site:test": "vitest run --config site/vite.config.ts",
    "site:test:browser": "vitest run --config site/tests/vitest.browser.config.ts",
    "build-index": "tsc && node dist/scripts/build-index.js",
    "bulk-import": "tsc && node dist/scripts/bulk-import.js",
    "review-draft": "tsc && node dist/scripts/review-draft.js",
    "commit-draft": "tsc && node dist/scripts/commit-draft.js",
    "migrate": "tsc && node dist/scripts/migrate-v1-to-v2.js",
    "migrate-layout": "tsc && node dist/scripts/migrate-layout-field.js",
    "migrate-untitled": "tsc && node dist/scripts/migrate-untitled-products.js",
    "migrate-platform": "tsc && node dist/scripts/migrate-platform.js",
    "migrate-wcag-ids": "tsc && node dist/scripts/migrate-wcag-ids.js",
    "corpus-stats": "tsc && node dist/scripts/corpus-stats.js",
    "query-stats": "tsc && node dist/scripts/query-stats.js",
    "restore-corpus": "tsc && node dist/scripts/restore-corpus.js",
    "clean-orphans": "tsc && node dist/scripts/clean-orphans.js",
    "dedup-cleanup": "tsc && node dist/scripts/dedup-cleanup.js",
    "doctor": "tsc && node dist/scripts/doctor.js",
    "pattern-discovery": "tsc && node dist/scripts/pattern-discovery.js",
    "eval-baseline": "tsc && node scripts/eval-baseline.mjs",
    "eval-matrix": "tsc && node scripts/eval-matrix.mjs",
    "benchmark-image-embeddings": "tsc && node scripts/benchmark-image-embeddings.mjs",
    "build-image-index": "tsc && node dist/scripts/build-image-index.js",
    "test:critique-quality": "vitest run scripts/critique-quality-scorer.test.mjs scripts/eval-scorer.test.mjs",
    "test:design-handoff-quality": "vitest run scripts/design-handoff-scorer.test.mjs",
    "test:c2-scoring": "vitest run src/c2/scorer.test.ts scripts/design-handoff-v1-regression.test.mjs scripts/design-handoff-scorer.test.mjs",
    "generate:c2-pilot": "node scripts/build-c2-pilot-manifest.mjs",
    "validate:c2-pilot": "node scripts/build-c2-pilot-manifest.mjs --check",
    "generate:c2-baseline": "node scripts/build-baseline-manifest.mjs",
    "validate:c2-baseline": "node scripts/build-baseline-manifest.mjs --check --allow-missing-snapshots",
    "generate:c2-label-selection": "tsx src/scripts/build-label-integrity-selection.mts",
    "validate:c2-label-selection": "tsx src/scripts/build-label-integrity-selection.mts --check",
    "validate:c2-label-selection:schema": "tsx src/scripts/build-label-integrity-selection.mts --verify-schema",
    "c2:pilot": "tsc && node dist/scripts/run-c2-pilot.js",
    "c2:baseline": "tsx src/scripts/run-c2-baseline.ts",
    "validate:c2-baseline-runner": "tsx src/scripts/run-c2-baseline.ts validate --manifest eval/c2/baseline/manifest.json --calibration eval/c2/calibration/frozen.json",
    "validate-readiness-artifacts": "tsc && node dist/scripts/validate-readiness-artifacts.js",
    "typecheck:contracts": "tsc --noEmit && tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --skipLibCheck src/tool-contract-types.test.ts"
  },
  "keywords": [
    "mcp",
    "design",
    "ui",
    "inspiration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.3",
    "image-size": "^2.0.2",
    "minisearch": "^7.2.0",
    "node-vibrant": "^4.0.4",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.1.9",
    "jsdom": "^28.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
