  "patterns": {
    "unlabeledControlRisk": {
      "source": "\\bicon[\\s-]*only|icons?\\s+(?:alone|symbols?\\s+alone)|icons?\\s+without\\s+(?:visible\\s+)?(?:text\\s+)?labels?|represented\\s+(?:solely\\s+)?by\\s+icons?|(?:icon|glyph|symbol|button|control)\\s+with\\s+(?:no|without)\\s+(?:a\\s+)?(?:visible\\s+)?(?:text\\s+)?labels?|(?:icon|glyph|symbol|button|control)\\s+(?:has|have|having)\\s+no\\s+(?:visible\\s+)?(?:text\\s+)?labels?|(?:icon|glyph|symbol|button|control)\\s+lack(?:s|ing)?\\s+(?:a\\s+)?(?:visible\\s+)?(?:text\\s+)?labels?|no\\s+(?:visible\\s+)?(?:text\\s+)?labels?\\s+(?:beside|next to|on|for|is visible)|no\\s+(?:visible\\s+)?(?:text\\s+)?labels?\\s+(?:are\\s+)?visible|(?:has|have)\\s+no\\s+(?:accompanying\\s+)?(?:visible\\s+)?(?:text\\s+)?labels?|no\\s+accompanying\\s+(?:visible\\s+)?(?:text\\s+)?labels?|lack(?:s|ing)?\\s+(?:an?\\s+|a\\s+)?(?:accompanying\\s+)?(?:visible\\s+)?(?:text\\s+)?labels?|no\\s+(?:visible\\s+)?accessible\\s+name|unlabeled\\s+(?:icon|button|control|nav)|rel(?:iance|ies|y)\\s+on\\s+(?:memorized\\s+)?(?:icon\\s+)?shapes?|\\bnaked\\s+icons?\\b|lacks?\\s+(?:an?\\s+)?accessible\\s+name|without\\s+(?:an?\\s+)?accessible\\s+name\\b",
      "flags": "i"
    },
    "pixelMeasurement": {
      "source": "\\b\\d+(?:\\.\\d+)?\\s*-?\\s*(?:px|pixel[s]?|pt|rem|em)\\b",
      "flags": "i"
    }
  },
  "exemptionPatterns": {
    "domGroundTruth": {
      "source": "\\b(?:dom|computed|contrast[\\s-]*ratio|accessibility\\s+tree|aria-|offsetwidth|offsetheight|getboundingclientrect|measured\\s+(?:from|via))\\b",
      "flags": "i"
    },
    "contrastClause": {
      "source": "\\b(?:instead\\s+of|rather\\s+than|avoids?|rejects?|unlike|in\\s+contrast\\s+to|could\\s+have|might\\s+(?:have\\s+)?(?:used|gone)|do\\s+not|does\\s+not|are\\s+not|is\\s+not|not\\s+(?:icon|going))\\b",
      "flags": "i"
    },
    "positiveLabelPairing": {
      "source": "\\b(?:paired?\\s+with|keeps?\\s+icons?\\s+paired|icons?\\s+(?:and|with)\\s+(?:text\\s+)?labels?|(?:text\\s+)?labels?\\s+(?:beside|next to|alongside)|instead\\s+of\\s+going\\s+icon[\\s-]*only)\\b",
      "flags": "i"
    }
  }
}
